# .sops.yaml — SOPS encryption rules
# Generated by Ansible. The age public key below is the operator's key.
# This file IS committed to Git (it contains only the public key).
#
# Encryption: sops --encrypt <file>
# Decryption: sops --decrypt <file>
# Edit in-place: sops <file>
creation_rules:
  # Kubernetes secrets (KSOPS integration)
  - path_regex: k8s/.*/secrets/.*\.enc\.yaml$
    age: >-
      {{ sops_age_public_key }}

  # Ansible encrypted vars (if any)
  - path_regex: iac/ansible/.*\.enc\.yml$
    age: >-
      {{ sops_age_public_key }}
