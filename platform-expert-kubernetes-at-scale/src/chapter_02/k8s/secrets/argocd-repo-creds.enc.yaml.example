# Example SOPS-encrypted Secret
# This is what the encrypted file looks like AFTER running sops --encrypt.
# The actual encrypted file (argocd-repo-creds.enc.yaml) is not included
# because it requires your age key to create.
#
# To create the real encrypted file:
#   1. Create a plaintext YAML with your actual credentials
#   2. Run: sops --encrypt --age <your-age-public-key> plaintext.yaml > argocd-repo-creds.enc.yaml
#   3. Delete the plaintext file
#   4. Commit argocd-repo-creds.enc.yaml to Git
#
# Plaintext structure (DO NOT commit this — encrypt first):
#
# apiVersion: v1
# kind: Secret
# metadata:
#   name: repo-credentials
#   namespace: argocd
#   labels:
#     argocd.argoproj.io/secret-type: repository
# type: Opaque
# stringData:
#   type: git
#   url: https://github.com/your-org/your-repo.git
#   password: ghp_your_github_personal_access_token
#   username: git
